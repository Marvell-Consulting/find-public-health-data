{
  "name": "@fphd/internal-web",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "cross-env NODE_ENV=development node --env-file-if-exists=../../.env server.ts",
    "preview": "pnpm build && pnpm start",
    "start": "cross-env NODE_ENV=production node server.ts",
    "test": "vitest run",
    "typecheck": "react-router typegen && tsc --noEmit"
  },
  "dependencies": {
    "@fphd/config": "workspace:*",
    "@fphd/internal-web-features": "workspace:*",
    "@fphd/logger": "workspace:*",
    "@fphd/public-web-features": "workspace:*",
    "@fphd/ui": "workspace:*",
    "@fphd/web-server": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router": "catalog:"
  },
  "devDependencies": {
    "@react-router/dev": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "cross-env": "catalog:",
    "jsdom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
