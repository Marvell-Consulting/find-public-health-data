{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "rootDirs": [".", ".react-router/types"],
    "types": ["vite/client", "node"]
  },
  "include": [
    ".react-router/types/**/*",
    "src",
    "server",
    "server.js",
    "react-router.config.ts",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
