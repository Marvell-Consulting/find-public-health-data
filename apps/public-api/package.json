{
  "name": "@fphd/public-api",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsx watch --env-file-if-exists=../../.env --conditions=development src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run --exclude '**/*.integration.test.*'",
    "test:integration": "vitest run --passWithNoTests integration.test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fphd/api-server": "workspace:*",
    "@fphd/config": "workspace:*",
    "@fphd/db": "workspace:*",
    "@fphd/logger": "workspace:*",
    "drizzle-orm": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/supertest": "catalog:",
    "supertest": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
