# Local development environment. Copy to `.env` and adjust as needed.
# `.env` is gitignored; this example is committed.
# The dev scripts load this file automatically (--env-file-if-exists); in deployed
# environments every value is injected by the platform instead.

# Deployment environment: local | dev | preview | production. Defaults to local.
#APP_ENV=local

# Per-app listen address and port. Defaults: host 0.0.0.0; public-web 3000,
# internal-web 3001, public-api 4000, internal-api 4001. A PORT set here applies to
# every app that loads this file, so leave it unset unless you are running one app.
#HOST=0.0.0.0
#PORT=4000

# Logging. LOG_LEVEL: fatal | error | warn | info | debug | trace (default info).
# Pretty printing applies only when APP_ENV is local (on by default; LOG_PRETTY=0 disables).
# Deployed environments always log JSON.
#LOG_LEVEL=info
#LOG_PRETTY=0

# Signs JWT session cookies issued by the authentication backend. This value is for local
# development only; inject a different secret of at least 32 bytes into each deployed service.
SESSION_JWT_SECRET=fphd-local-development-jwt-secret-change-before-deploying

# Database connection, shared by all roles.
DB_HOST=localhost
DB_PORT=5432
POSTGRES_DB=fphd

# Owner role — used by the Postgres container and by drizzle-kit for migrations.
POSTGRES_USER=fphd
POSTGRES_PASSWORD=fphd

# Per-API role passwords (role names are fixed: public_api / internal_api).
# Single source of truth: the init script creates the roles with these, and each
# API connects with them.
PUBLIC_API_PASSWORD=public_api
INTERNAL_API_PASSWORD=internal_api
