{
  "name": "find-public-health-data",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=24.18.0 <25",
    "pnpm": ">=11.11.0 <12"
  },
  "scripts": {
    "build": "pnpm --recursive run build",
    "check": "biome check . && pnpm typecheck && pnpm test && pnpm build",
    "check:write": "biome check --write .",
    "db:generate": "pnpm --filter @fphd/config build && pnpm --filter @fphd/db db:generate",
    "db:migrate": "pnpm --filter @fphd/config build && pnpm --filter @fphd/db db:migrate",
    "db:studio": "pnpm --filter @fphd/config build && pnpm --filter @fphd/db db:studio",
    "dev": "pnpm --recursive --parallel run dev",
    "dev:internal": "pnpm --parallel --filter @fphd/internal-web --filter @fphd/internal-api run dev",
    "dev:public": "pnpm --parallel --filter @fphd/public-web --filter @fphd/public-api run dev",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "test": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "test:e2e": "pnpm --recursive run --if-present test:e2e",
    "test:integration": "pnpm --recursive run test:integration",
    "test:unit": "pnpm --recursive run test",
    "typecheck": "pnpm --recursive run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:"
  }
}
