{
  "name": "@fphd/web-server",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/host.ts",
      "types": "./src/host.ts",
      "default": "./dist/host.js"
    },
    "./entry-server": {
      "development": "./src/entry-server.tsx",
      "types": "./src/entry-server.tsx",
      "default": "./dist/entry-server.js"
    },
    "./react-router": {
      "development": "./src/react-router-app.ts",
      "types": "./src/react-router-app.ts",
      "default": "./dist/react-router-app.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-router/express": "catalog:",
    "@react-router/node": "catalog:",
    "express": "catalog:",
    "isbot": "catalog:",
    "morgan": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router": "catalog:"
  },
  "devDependencies": {
    "@types/express": "catalog:",
    "@types/morgan": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/supertest": "catalog:",
    "supertest": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
